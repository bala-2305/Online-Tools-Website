      { "source": "/video-gif", "destination": "/video-to-gif.html" },
      { "source": "/slideshow", "destination": "/slideshow-video-maker.html" },
      { "source": "/screenshot", "destination": "/website-screenshot-tool.html" },

      { "source": "/social", "destination": "/socialmedia.html" },
      { "source": "/seo-tools", "destination": "/marketing-seo-tools.html" },
      { "source": "/builder", "destination": "/genai-builder.html" },
      { "source": "/ocr", "destination": "/ocr.html" },
      { "source": "/tts", "destination": "/text-to-speech-reader.html" },
      { "source": "/faker", "destination": "/fake-data-generator.html" },
      { "source": "/color", "destination": "/color-picker.html" },
      { "source": "/gradient", "destination": "/css-gradient-generator.html" },

      { "source": "/about", "destination": "/about.html" },
      { "source": "/features", "destination": "/features.html" },
      { "source": "/contact", "destination": "/contact.html" },
      { "source": "/privacy", "destination": "/privacy.html" },

      { "source": "/nova", "destination": "/novaaiweb/index.html" },
      { "source": "/nova/chat", "destination": "/novaaiweb/index.html" },
      { "source": "/nova/code", "destination": "/novaaiweb/code-assistant.html" },
      { "source": "/face", "destination": "/humanai/det/index.html" },
      { "source": "/:page", "destination": "/:page.html" },
      { "source": "/**", "destination": "/index.html" }
    ]
  }
}
