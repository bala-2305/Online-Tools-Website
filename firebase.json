      { "source": "/port", "destination": "/port-scanner.html" },
      { "source": "/indexnow", "destination": "/indexnow-manager.html" },

      { "source": "/qrcode", "destination": "/qrcode-generator.html" },
      { "source": "/meta", "destination": "/meta-tag-generator.html" },
      { "source": "/favicon", "destination": "/favicon-generator.html" },
      { "source": "/seo", "destination": "/seo-keyword-analyzer.html" },
      { "source": "/sitemap", "destination": "/sitemap-generator.html" },

      { "source": "/converter", "destination": "/unit-converter.html" },
      { "source": "/loan", "destination": "/loan-emi-calculator.html" },
      { "source": "/gst", "destination": "/gst-calculator.html" },
      { "source": "/gpa", "destination": "/gpa-calculator.html" },
